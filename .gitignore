# DroidRecon .gitignore

# Python
__pycache__/
*.py[cod]
*$py.class
*.pyc
.Python
*.egg-info/
dist/
build/
.eggs/

# Virtual environments
.venv/
venv/
env/
ENV/

# Output files (don't commit scan results)
*.json
*.html
*.sarif
!config/regexes.json

# Decompiled APK temp directories
apkleakspro_*
droidrecon_tmp_*/
/decompiled/

# IDE
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Jadx output
out/

# Test APKs (never commit APKs to public repos)
*.apk
*.aab

# Reports
reports/
